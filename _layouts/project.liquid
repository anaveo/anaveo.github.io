---
layout: default
---
<div class="page-project">

  <!-- Header -->
  <header class="project-header">
    <nav class="project-breadcrumb" aria-label="Breadcrumb">
      <a href="{{ site.baseurl }}/">Projects</a>
      <span aria-hidden="true">/</span>
      <span>{{ page.title }}</span>
    </nav>
    {% if page.category %}
      <p class="project-category">{{ page.category }}</p>
    {% endif %}
    <h1 class="project-title">{{ page.title }}</h1>
    {% if page.description %}
      <p class="project-description">{{ page.description }}</p>
    {% endif %}
  </header>

  <!-- Hero image -->
  {% if page.img %}
    <div class="project-hero-img">
      <img src="{{ page.img | relative_url }}" alt="{{ page.title }}" loading="eager">
    </div>
  {% endif %}

  <!-- Content -->
  <div class="project-content prose">
    {{ content }}
  </div>

  <!-- Back link -->
  <a href="{{ site.baseurl }}/" class="back-to-projects">← All Projects</a>

</div>
