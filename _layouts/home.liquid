---
layout: default
---
<div class="page-home">

  <!-- Hero -->
  <section class="hero">
    <p class="hero-eyebrow">Portfolio</p>
    <h1 class="hero-headline">Hardware &amp; Software Projects</h1>
    <p class="hero-sub">Engineer and tinkerer building at the intersection of embedded systems, robotics, and software.</p>
  </section>

  <!-- Project Grid -->
  <section class="projects-section">
    <div class="section-header">
      <span class="section-label">Projects</span>
      <span class="section-count">{{ site.projects | size }}</span>
    </div>

    {% assign sorted_projects = site.projects | sort: "date" | reverse %}
    {% assign project_count = site.projects | size %}

    <div class="project-grid">
      {% for project in sorted_projects %}
        {% assign card_class = "project-card" %}
        {% if project.featured %}{% assign card_class = "project-card featured" %}{% endif %}
        <a href="{{ project.url | relative_url }}" class="{{ card_class }}">

          <!-- Image -->
          <div class="card-img-wrap">
            {% if project.img %}
              <img
                src="{{ project.img | relative_url }}"
                alt="{{ project.title }}"
                loading="lazy"
              >
            {% else %}
              <div class="card-img-placeholder">
                <span>{{ project.title | slice: 0 }}</span>
              </div>
            {% endif %}
          </div>

          <!-- Body -->
          <div class="card-body">
            {% if project.category %}
              <span class="card-category">{{ project.category }}</span>
            {% endif %}
            <h2 class="card-title">{{ project.title }}</h2>
            {% if project.description %}
              <p class="card-desc">{{ project.description }}</p>
            {% endif %}
          </div>

          <!-- Footer -->
          <div class="card-footer">
            {% if project.date %}
              <time>{{ project.date | date: "%Y" }}</time>
            {% else %}
              <span></span>
            {% endif %}
            <span class="card-arrow">→</span>
          </div>

        </a>
      {% endfor %}
    </div>
  </section>

</div>
